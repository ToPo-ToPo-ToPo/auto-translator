#!/bin/bash
# auto-translator launcher (double-clickable .app on macOS).
# Resolves the project dir, ensures the uv-managed venv exists, starts the
# local server, and opens the browser. Stays alive while the server runs so
# quitting the app (Dock > Quit) stops it.

set -e

# Project dir: normally the folder containing this .app. If you move
# auto-translator.app out of its project folder (e.g. to /Applications), set
# AUTO_TRANSLATE_HOME to the absolute path of your cloned auto-translator dir.
PROJECT="$(cd "$(dirname "$0")/../../.." && pwd)"
if [ ! -f "$PROJECT/app.py" ] && [ -n "$AUTO_TRANSLATE_HOME" ]; then
  PROJECT="$AUTO_TRANSLATE_HOME"
fi
if [ ! -f "$PROJECT/app.py" ]; then
  osascript -e 'display alert "auto-translator" message "プロジェクトフォルダが見つかりません。auto-translator.app はクローンしたフォルダ内に置くか、環境変数 AUTO_TRANSLATE_HOME にそのパスを設定してください。"'
  exit 1
fi
cd "$PROJECT"

URL="http://127.0.0.1:8765"

# Already running? Don't start a second instance (its window is already open).
if curl -s -o /dev/null --max-time 1 "$URL/api/config"; then
  exit 0
fi

LOG="$PROJECT/app.log"

# GUI launches don't inherit your shell PATH, so locate uv explicitly.
find_uv() {
  for p in \
    /opt/homebrew/bin/uv \
    "$HOME/.local/bin/uv" \
    /usr/local/bin/uv \
    "$HOME/.cargo/bin/uv" \
    "$(command -v uv 2>/dev/null)" ; do
    [ -n "$p" ] && [ -x "$p" ] && { echo "$p"; return 0; }
  done
  return 1
}

UV="$(find_uv)" || {
  osascript -e 'display alert "auto-translator" message "uv が見つかりませんでした。Terminal で「brew install uv」を実行してから、もう一度アプリを開いてください。"'
  exit 1
}

# Ensure the venv + core deps exist (fast no-op once synced). uv provisions a
# matching Python on its own if needed.
"$UV" sync >>"$LOG" 2>&1

# Run the app: it serves locally and opens its own native window (pywebview).
# This process == the app's lifetime; closing the window exits it.
exec "$UV" run python app.py >>"$LOG" 2>&1
