#!/bin/bash
# auto-translator launcher (double-clickable .app on macOS).
# Resolves the project dir, ensures the uv-managed venv exists, starts the
# local server, and opens the browser. Stays alive while the server runs so
# quitting the app (Dock > Quit) stops it.

set -e

# Project dir: normally the folder containing this .app. If the .app has been
# moved (e.g. to /Applications or the Dock), fall back to the known location.
PROJECT="$(cd "$(dirname "$0")/../../.." && pwd)"
if [ ! -f "$PROJECT/app.py" ]; then
  PROJECT="/path/to/auto-translator"
fi
cd "$PROJECT"

URL="http://127.0.0.1:8765"

# Already running? Just focus the browser and exit.
if curl -s -o /dev/null --max-time 1 "$URL/api/config"; then
  open "$URL"
  exit 0
fi

LOG="$PROJECT/app.log"

# GUI launches don't inherit your shell PATH, so locate uv explicitly.
find_uv() {
  for p in \
    /opt/homebrew/bin/uv \
    "$HOME/.local/bin/uv" \
    /usr/local/bin/uv \
    "$HOME/.cargo/bin/uv" \
    "$(command -v uv 2>/dev/null)" ; do
    [ -n "$p" ] && [ -x "$p" ] && { echo "$p"; return 0; }
  done
  return 1
}

UV="$(find_uv)" || {
  osascript -e 'display alert "auto-translator" message "uv が見つかりませんでした。Terminal で ./run.sh を実行するか、uv をインストールしてください。"'
  exit 1
}

# Ensure the venv + core deps exist (fast no-op once synced). uv provisions a
# matching Python on its own if needed.
"$UV" sync >>"$LOG" 2>&1

# Open the browser shortly after the server comes up.
( sleep 1; open "$URL" ) &

# Run the server in the foreground so this process == the app's lifetime.
exec "$UV" run python app.py --no-browser >>"$LOG" 2>&1
